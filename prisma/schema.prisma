generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  password     String
  role         String   @default("user")
  organization String?
  createdAt    DateTime @default(now())

  records   EnergyRecord[]
  scenarios Scenario[]
}

model EnergyRecord {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  device      String
  location    String?
  consumption Float
  power       Float?
  recordedAt  DateTime
  createdAt   DateTime @default(now())
}

model Scenario {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  name        String
  description String?
  mode        String
  savings     Float?
  createdAt   DateTime @default(now())
}