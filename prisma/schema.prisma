generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // тепер опціональний — Google юзери не мають пароля
  role          String    @default("user")
  organization  String?
  createdAt     DateTime  @default(now())

  accounts  Account[]
  sessions  Session[]
  records   EnergyRecord[]
  scenarios Scenario[]
}

// --- Обов'язкові моделі для NextAuth ---
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model EnergyRecord {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  device      String
  location    String?
  consumption Float
  power       Float?
  recordedAt  DateTime
  createdAt   DateTime @default(now())
}

model Scenario {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  name        String
  description String?
  mode        String
  savings     Float?
  createdAt   DateTime @default(now())
}

model InverterRecord {
  id                String   @id @default(cuid())
  timestamp         DateTime // година доби: 2026-04-14T10:00:00Z
  statisticalPeriod String   // "10:00"
  globalIrradiation Float    // кВт·год/м²
  avgTemperature    Float    // °C
  theoreticalYield  Float    // кВт·год
  pvYield           Float    // кВт·год
  inverterYield     Float    // кВт·год
  export            Float    // кВт·год
  import            Float    // кВт·год
  lossExportKwh     Float    // кВт·год
  lossExportEur     Float    // €
  charge            Float    // кВт·год
  discharge         Float    // кВт·год
  revenue           Float    // €

  @@unique([timestamp])
  @@index([timestamp])
}